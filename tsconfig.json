{
	"compilerOptions": {
		"target": "esnext",
		"lib": [
			"esnext",
			"dom",
		],
		"module": "nodenext",
		"types": [
			"node",
		],
		"allowImportingTsExtensions": true,
		"erasableSyntaxOnly": true,
		"strict": true,
		"noEmit": true,
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
	},
}
